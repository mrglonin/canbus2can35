.DS_Store
__pycache__/
*.pyc

# Keep public repository clean. Put local binaries here when working locally,
# but do not publish third-party APK/firmware without explicit rights.
firmware/local/
*.apk
*.bin
*.elf
*.map

# These are project artifacts intentionally published for our own CAN logging
# work. Keep other random binaries ignored.
!firmware/canlog/
!firmware/canlog/*.bin

# Local captures can grow fast. Curated examples may be force-added if needed.
logs/*.tmp
logs/live_*.txt
logs/live_*.log

# Local reverse-engineering decode/disassembly outputs.
re/
