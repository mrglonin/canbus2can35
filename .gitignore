.DS_Store
**/.DS_Store
__pycache__/
*.pyc
*.o
*.elf
*.map

.gradle/
build/
local.properties
.idea/
android/**/.gradle/
android/**/build/
android/**/.idea/

# Generated outputs stay outside git. The clean public artifacts are copied to
# /Volumes/SSD/canbus/release.
release/
*.apk
!updates/
!updates/*.apk
!updates/*.json

# Keep random firmware dumps out of git. Only trusted, documented binaries are
# allowed in firmware/trusted.
*.bin
!firmware/trusted/
!firmware/trusted/**/*.bin
firmware/local/
firmware/scripts/
firmware/**/*.report.json

# Local captures and reverse-engineering workspaces are intentionally external.
logs/
re/
analysis/
dist/
samples/
.tools/
tools/
