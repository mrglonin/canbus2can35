.DS_Store
**/.DS_Store
__pycache__/
*.pyc
*.o
*.elf
*.map

.gradle/
build/
local.properties
.idea/
android/**/.gradle/
android/**/build/
android/**/.idea/

# Generated outputs stay outside git. The clean public artifacts are copied to
# /Volumes/SSD/canbus/release.
release/
*.apk
!updates/
!updates/*.apk
!updates/*.json

# Keep random firmware dumps out of git. Only trusted, documented binaries are
# allowed in firmware/trusted.
*.bin
!firmware/trusted/
!firmware/trusted/**/*.bin
firmware/local/
firmware/scripts/
firmware/**/*.report.json

# Private protocol notes stay local only.
docs/ADAPTER_FIRMWARE_SIGNAL_MAP.md
docs/APK_V20_REWORK_PLAN.md
docs/FIRMWARE_ADAPTER_OWNED_LOGIC_TARGET.md
docs/FIRMWARE_V18_OBD_SNAPSHOT.md
docs/FIRMWARE_V19_CAN_TX.md
docs/FIRMWARE_V20_ADAPTER.md
docs/FIRMWARE_V21_ADAPTER.md
docs/FM_UART_TO_MCAN_TRACE.md
docs/PROGRAMMER_FIRMWARE_DECODE.md
docs/PROGRAMMER_FIRMWARE_UART_CHECK.md
docs/TEYES_APP_IMPLEMENTATION_README_20260513.md
docs/TRUSTED_FIRMWARE_FACTS.md

# Local captures and reverse-engineering workspaces are intentionally external.
logs/
re/
analysis/
dist/
samples/
.tools/
tools/
