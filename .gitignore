.DS_Store
__pycache__/
*.pyc

# Keep public repository clean. Put local binaries here when working locally,
# but do not publish third-party APK/firmware without explicit rights.
firmware/local/
*.apk
*.bin
*.elf
*.map

# Local captures can grow fast. Curated examples may be force-added if needed.
logs/*.tmp
logs/live_*.txt
logs/live_*.log
